# ─── Splyntra (required) ─────────────────────────────────────────────
# API key for the project this service reports to. In Splyntra Cloud, mint
# this per-project under Settings → Keys; self-host dev accepts splyntra_dev_key.
SPLYNTRA_API_KEY=splyntra_dev_key
# Logical project name traces are grouped under.
SPLYNTRA_PROJECT=support-triage
# Collector OTLP endpoint. Self-host default below; Cloud uses your ingest host.
SPLYNTRA_ENDPOINT=http://localhost:4318

# ─── Runtime ─────────────────────────────────────────────────────────
# production | staging | development — sets the trace environment label and
# turns on stricter startup checks. Defaults to development if unset.
NODE_ENV=production
PORT=8080
# Per-request budget. The agent aborts and returns 504 if it runs longer.
REQUEST_TIMEOUT_MS=15000

# ─── LLM provider (optional) ─────────────────────────────────────────
# When set, the service calls OpenAI for real (auto-instrumented by the SDK).
# When unset, it runs a clearly-labeled simulated completion so you can see
# traces flow without an OpenAI account.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
